{
  "name": "telegram-profit-copilot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch src/server/main.ts",
    "dev:dashboard": "vite --config vite.dashboard.config.ts",
    "build:server": "tsc -p tsconfig.server.json && node -e \"const { mkdirSync, copyFileSync } = require('fs'); mkdirSync('dist/server/db', { recursive: true }); mkdirSync('dist/server/shared/generated', { recursive: true }); copyFileSync('src/server/db/schema.sql', 'dist/server/db/schema.sql'); copyFileSync('src/shared/generated/gameData.json', 'dist/server/shared/generated/gameData.json');\"",
    "build:dashboard": "vite build --config vite.dashboard.config.ts",
    "test": "jest --config jest.config.cjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "fastify": "^4.28.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router": "^7.12.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vite": "^5.4.14"
  }
}
