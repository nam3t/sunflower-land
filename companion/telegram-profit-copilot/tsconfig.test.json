{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "isolatedModules": true,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": true,
    "rootDir": ".",
    "types": ["node", "jest"]
  },
  "include": [
    "src/server/**/*.ts",
    "src/dashboard/**/*.ts",
    "src/dashboard/**/*.tsx",
    "test/**/*.ts",
    "test/**/*.tsx"
  ]
}
